@startuml
actor User
participant ":Parser" as P
participant ":UnarchiveCommand" as UC
participant ":ApplicationList" as AL
participant "app:Application" as app
participant ":Storage" as S

User -> P : parse("unarchive 1")
P --> UC : create

UC -> AL : getArchivedApplication(1)
AL --> UC : app
UC -> app : setArchived(false)
UC -> S : save(...)
UC --> User : confirmation message
@enduml
