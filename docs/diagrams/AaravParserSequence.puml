@startuml
actor User
participant ":Ui" as UI
participant ":InternTrackr" as IT
participant ":Parser" as P
participant ":AddCommandParser" as ACP
participant ":DeleteCommandParser" as DCP
participant ":ArchiveCommandParser" as ArCP

User -> UI : types command
IT -> UI : readCommand()
UI --> IT : fullCommand

IT -> P : parse(fullCommand)

alt command word is "add"
    P -> ACP : parse(arguments)
    ACP --> P : c (AddCommand)
else command word is "delete"
    P -> DCP : parse(arguments)
    DCP --> P : c (DeleteCommand)
else command word is "archive"
    P -> ArCP : parse(arguments)
    ArCP --> P : c (ArchiveCommand)
else command is "list archive"
    note right of P
      Handled directly in Parser.
      No separate ListArchiveCommandParser exists.
    end note
    P --> IT : c (ListArchiveCommand)
else command is "list"
    P --> IT : c (ListCommand)
end

P --> IT : command
@enduml
