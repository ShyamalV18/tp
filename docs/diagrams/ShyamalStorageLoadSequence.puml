@startuml
actor User
participant ":InternTrackr" as IT
participant ":Ui" as UI
participant ":Storage" as S
participant ":ApplicationList" as AL

User -> IT : launches app
activate IT

IT -> S : load()
activate S

alt file does not exist
    S --> IT : empty ArrayList
else file exists
    S -> S : parseLine() for each line
    note right of S : Parses each line into\nApplication objects.\nThrows InternTrackrException\nif any line is corrupted.
    S --> IT : ArrayList<Application>
end

deactivate S

alt load successful
    IT -> AL : new ApplicationList(applications)
    activate AL
    AL --> IT : applicationList
    deactivate AL
else InternTrackrException thrown
    IT -> UI : showLoadingError()
    activate UI
    UI --> IT : done
    deactivate UI
    IT -> AL : new ApplicationList()
    activate AL
    AL --> IT : empty applicationList
    deactivate AL
end

deactivate IT
IT --> User : app ready
@enduml
