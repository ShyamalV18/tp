@startuml
actor User
participant ":Ui" as UI
participant ":InternTrackr" as IT
participant ":Parser" as P
participant "c:OverviewCommand" as OC
participant ":ApplicationList" as AL
participant "app:Application" as App

User -> UI : types "overview"
UI -> IT : readCommand()
IT --> UI : "overview"
IT -> P : parse("overview")
P --> IT : c (OverviewCommand)

IT -> OC : execute(applications, ui, storage)

OC -> AL : getSize()
AL --> OC : size

OC -> AL : getApplications()
AL --> OC : list

loop for each app in list
    OC -> App : getStatus()
    App --> OC : status
end

OC -> UI : showMessage(summary messages)
UI --> OC

OC --> IT
IT -> UI : showLine()
UI -> User : displays output
@enduml
